                onClick={() => window.location.reload()}
                title="Reload dashboard (re-fetches the latest compiled file)"
                style={{ fontFamily: FONT_MONO, fontSize: 10, fontWeight: 500, padding: "3px 10px", borderRadius: 5, border: `1px solid ${C.border}`, background: C.surface, color: C.textMid, cursor: "pointer", display: "inline-flex", alignItems: "center", gap: 4, transition: "all 0.12s" }}
                onMouseEnter={(e) => { e.currentTarget.style.background = C.surfaceAlt; e.currentTarget.style.borderColor = C.borderHover; e.currentTarget.style.color = C.text; }}
                onMouseLeave={(e) => { e.currentTarget.style.background = C.surface; e.currentTarget.style.borderColor = C.border; e.currentTarget.style.color = C.textMid; }}
              >
                ↻ Reload
              </button>
            </div>
          </div>
          <div style={{ marginBottom: 20 }}><Greeting /></div>
          <div style={{ height: 1, background: C.border }} />
        </div>

        {/* DAY MODE */}
        {mode === "day" && (
          <>
            <DayNavigator selectedDayIso={selectedDayIso} setSelectedDayIso={setSelectedDayIso} />

            <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 18, flexWrap: "wrap" }}>
              <span style={{ fontFamily: FONT_MONO, fontSize: 11, background: C.blueBg, color: C.blue, border: `1px solid ${C.blueBorder}`, borderRadius: 20, padding: "3px 13px", fontWeight: 600 }}>
                {dayMeta.name} {dayMeta.dayNum} {dayMeta.monthShort} · {active.length} discovery calls
              </span>
              {other.length > 0 && <span style={{ fontFamily: FONT_MONO, fontSize: 10, color: C.textHint }}>{other.length} other events</span>}
              {!isToday && <span style={{ fontFamily: FONT_MONO, fontSize: 9, color: C.textHint, fontStyle: "italic" }}>HubSpot enrichment runs the morning of</span>}
            </div>

            {isToday && (
              <>
                <NowIndicator prospects={dayProspects} />
                <Progress prospects={dayProspects} />
                <Timeline prospects={dayProspects} otherEvents={dayOtherEvents} />
                <OpenSlots prospects={dayProspects} otherEvents={dayOtherEvents} />
              </>
            )}

            <div style={{ fontFamily: FONT_MONO, fontSize: 9, letterSpacing: 0.8, textTransform: "uppercase", color: C.textHint, marginBottom: 12 }}>Discovery calls</div>
            {active.length === 0 ? (
              <div style={{ padding: "24px 16px", background: C.surface, border: `1px dashed ${C.border}`, borderRadius: 6, fontFamily: FONT_MONO, fontSize: 11, color: C.textHint, textAlign: "center" }}>No discovery calls scheduled.</div>
            ) : (
              active.map((m, i) => <ProspectCard key={i} m={m} notes={notes} setNotes={setNotes} onOpenNotes={setActiveNotes} />)
            )}

            {other.length > 0 && (
              <div style={{ marginTop: 28 }}>
                <div style={{ fontFamily: FONT_MONO, fontSize: 9, letterSpacing: 0.8, textTransform: "uppercase", color: C.textHint, marginBottom: 12 }}>Rest of day</div>
                {other.map((ev, i) => <OtherCard key={i} ev={ev} />)}
              </div>
            )}

            {isToday && <DayStats prospects={dayProspects} />}
          </>
        )}

        {/* WEEK MODE */}
        {mode === "week" && (
          <>
            <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 18, flexWrap: "wrap" }}>
              <span style={{ fontFamily: FONT_MONO, fontSize: 11, background: C.blueBg, color: C.blue, border: `1px solid ${C.blueBorder}`, borderRadius: 20, padding: "3px 13px", fontWeight: 600 }}>
                Week of {WEEK_DAYS[0].dayNum}-{WEEK_DAYS[WEEK_DAYS.length - 1].dayNum} {WEEK_DAYS[0].monthShort} · {Object.values(WEEK_PROSPECTS).reduce((acc, arr) => acc + arr.filter((p) => !p.canceled).length, 0)} calls
              </span>
              <span style={{ fontFamily: FONT_MONO, fontSize: 10, color: C.textHint }}>Toggle to Day for live timeline + notes</span>
            </div>
            <WeeklyView />
          </>
        )}

        {/* RE-ENGAGE MODE */}
        {mode === "reengage" && (
          <>
            <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 18, flexWrap: "wrap" }}>
              <span style={{ fontFamily: FONT_MONO, fontSize: 11, background: C.amberBg, color: C.amber, border: `1px solid ${C.amberBorder}`, borderRadius: 20, padding: "3px 13px", fontWeight: 600 }}>
                Re-engage · W-1 + W-2 · unqualified only
              </span>
              <span style={{ fontFamily: FONT_MONO, fontSize: 10, color: C.textHint }}>Yellow = freshest. Mark Done once you've reached out.</span>
            </div>
            <ReEngageTab />
          </>
        )}

        {/* Footer */}
        <div style={{ marginTop: 36, paddingTop: 16, borderTop: `1px solid ${C.border}`, fontFamily: FONT_MONO, fontSize: 9, color: C.textHint, letterSpacing: 1, lineHeight: 1.6 }}>
          {REFRESHED_AT} · {OWNER.email} · Auto-refresh weekdays at 07:30
        </div>
      </div>

      {activeNotes && (
        <LiveNotesModal
          prospect={activeNotes}
          notes={notes}
          setNotes={setNotes}
          onClose={() => setActiveNotes(null)}
        />
      )}
    </div>
  );
}
